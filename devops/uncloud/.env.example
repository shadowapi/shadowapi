# ShadowAPI Uncloud Deployment Environment Variables
# Copy to .env and fill in the values before deploying

# =============================================================================
# External PostgreSQL Database (Required)
# =============================================================================
# Connection string for your managed PostgreSQL instance
# Examples:
#   Supabase: postgres://user:pass@db.xxx.supabase.co:5432/postgres
#   Neon: postgres://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb
#   AWS RDS: postgres://user:pass@xxx.rds.amazonaws.com:5432/shadowapi
BE_DB_URI=postgres://user:password@your-postgres-host:5432/shadowapi?sslmode=require

# Hydra needs its own database (can be same host, different db)
HYDRA_DSN=postgres://user:password@your-postgres-host:5432/hydra?sslmode=require

# =============================================================================
# External NATS (Required)
# =============================================================================
# NATS JetStream connection URL
# Example: nats://user:pass@nats.your-provider.com:4222
BE_QUEUE_URL=nats://your-nats-host:4222
BE_QUEUE_PREFIX=shadowapi

# =============================================================================
# Hydra OAuth2 Secrets (Required)
# =============================================================================
# Generate secure random strings for production:
#   openssl rand -hex 32
HYDRA_SECRETS_SYSTEM=your-32-byte-hex-secret-here
OIDC_PAIRWISE_SALT=your-16-char-salt

# =============================================================================
# OAuth2 SPA Client (Required)
# =============================================================================
# After first deployment, create OAuth2 client and paste ID here:
#   uncloud exec mp-hydra -- hydra create client \
#     --endpoint http://localhost:4445 \
#     --grant-type authorization_code,refresh_token \
#     --response-type code \
#     --scope openid,offline_access \
#     --redirect-uri https://api.meshpump.com/api/v1/auth/oauth2/callback \
#     --name "ShadowAPI SPA" \
#     --token-endpoint-auth-method none \
#     --format json
BE_OAUTH2_SPA_CLIENT_ID=your-oauth2-client-id

# =============================================================================
# Initial Admin User (Required for first deployment)
# =============================================================================
BE_INIT_ADMIN_EMAIL=admin@example.com
BE_INIT_ADMIN_PASSWORD=YourSecurePassword123!

# =============================================================================
# SMTP / Amazon SES (Required for email - invites, password reset)
# =============================================================================
# Amazon SES SMTP credentials
# See: https://docs.aws.amazon.com/ses/latest/dg/smtp-credentials.html
BE_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
BE_SMTP_PORT=587
BE_SMTP_USERNAME=your-ses-smtp-username
BE_SMTP_PASSWORD=your-ses-smtp-password
# Must match a verified identity in SES
BE_SMTP_FROM=noreply@meshpump.com
BE_SMTP_FROM_NAME=MeshPump

# =============================================================================
# Optional Settings
# =============================================================================
BE_LOG_LEVEL=INFO
BE_JWKS_CACHE_DURATION=300
HYDRA_LOG_LEVEL=info
