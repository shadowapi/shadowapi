# Domain & Networking
BE_DOMAIN=localtest.me
BE_BASE_URL=http://localtest.me
BE_TRAEFIK_ENTRYPOINT=web

# Backend Application
BE_HOST=0.0.0.0
BE_PORT=8080
BE_LOG_LEVEL=DEBUG
BE_QUEUE_URL=nats://nats:4222
BE_QUEUE_PREFIX=shadowapi
BE_DB_URI=postgres://shadowapi:shadowapi@db/shadowapi

# Database
POSTGRES_PASSWORD=shadowapi
POSTGRES_USER=shadowapi
POSTGRES_DB=shadowapi

# Ory Kratos Configuration
KRATOS_DSN=postgres://shadowapi:shadowapi@db:5432/kratos?sslmode=disable
KRATOS_SECRETS_DEFAULT=CHANGE_ME_KRATOS_SECRETS_DEFAULT_32
KRATOS_SECRETS_COOKIE=CHANGE_ME_KRATOS_SECRETS_COOKIE_32
KRATOS_LOG_LEVEL=debug

# Ory Hydra Configuration
HYDRA_DSN=postgres://shadowapi:shadowapi@db:5432/hydra?sslmode=disable
HYDRA_SECRETS_SYSTEM=CHANGE_ME_HYDRA_SECRETS_SYSTEM_32
HYDRA_URLS_SELF_ISSUER=http://localtest.me
HYDRA_URLS_LOGIN=http://localtest.me/auth/login
HYDRA_URLS_CONSENT=http://hydra-consent:8080/consent
HYDRA_URLS_LOGOUT=http://localtest.me/auth/logout
HYDRA_LOG_LEVEL=debug
OIDC_PAIRWISE_SALT=CHANGE_ME_SALT16
