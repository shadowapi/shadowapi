# Domain & Networking
BE_DOMAIN=localtest.me
BE_BASE_URL=http://localhost.me
BE_TRAEFIK_ENTRYPOINT=web

# Backend Application
BE_HOST=0.0.0.0
BE_PORT=8080
BE_LOG_LEVEL=DEBUG
BE_AUTH_USER_MANAGER=zitadel
BE_QUEUE_URL=nats://nats:4222
BE_QUEUE_PREFIX=shadowapi
BE_DB_URI=postgres://shadowapi:shadowapi@db/shadowapi

# Database
POSTGRES_PASSWORD=shadowapi
POSTGRES_USER=shadowapi
POSTGRES_DB=shadowapi

# Zitadel Configuration
BE_ZITADEL_URL=http://auth.localtest.me
BE_ZITADEL_REDIRECT_URL=http://localtest.me/login
BE_ZITADEL_MANAGEMENT_URL=http://zitadel:8080
BE_ZITADEL_SERVICE_USER_KEY_PATH=/secrets/shadowapi-admin-service.json

# Zitadel Database
ZITADEL_DATABASE_POSTGRES_HOST=db
ZITADEL_DATABASE_POSTGRES_PORT=5432
ZITADEL_DATABASE_POSTGRES_DATABASE=zitadel
ZITADEL_DATABASE_POSTGRES_USER_USERNAME=zitadel
ZITADEL_DATABASE_POSTGRES_USER_PASSWORD=zitadel
ZITADEL_DATABASE_POSTGRES_USER_SSL_MODE=disable
ZITADEL_DATABASE_POSTGRES_ADMIN_USERNAME=shadowapi
ZITADEL_DATABASE_POSTGRES_ADMIN_PASSWORD=shadowapi
ZITADEL_DATABASE_POSTGRES_ADMIN_SSL_MODE=disable

# Zitadel Login UI
ZITADEL_API_URL=http://auth.localtest.me:8080
NEXT_PUBLIC_BASE_PATH=/ui/v2/login
ZITADEL_SERVICE_USER_TOKEN_FILE=/secrets/shadowapi-client-service.pat

# Generated by docker compose --profile init up
VITE_ZITADEL_CLIENT_ID=
